package Expenses::App::Command::Total;
use strict;
use warnings;
use App::Cmd::Setup -command;
use DateTime::Format::Strptime;
use Expenses::DB;
use Expenses::Format;

sub abstract { "Print total expenses stored in the database" }

sub opt_spec {
    return (
        [ "date=s",   "date e.g. 'May, 09, 2026' (default: today)" ],
    );
}

sub execute {
    my ($self, $opt, $args) = @_;

    my $dt;
    if (defined $opt->date) {
        my $parser = DateTime::Format::Strptime->new(
            pattern  => '%B, %d, %Y',
            on_error => 'croak',
        );
        $dt = $parser->parse_datetime($opt->date);
        my $formatted = $dt->strftime('%Y-%m-%d');
        Expenses::DB::with_db(sub {
            my ($dbh) = @_;
            my $total = Expenses::DB::get_total($dbh, $formatted);
            printf "Total: \$%s\n", Expenses::Format::cents_to_dollars($total);
        });
    } else {
        Expenses::DB::with_db(sub {
            my ($dbh) = @_;
            my $total = Expenses::DB::get_total($dbh);
            printf "Total: \$%s\n", Expenses::Format::cents_to_dollars($total);
        });
    }
}

1;
